# Copy to .env and fill in. .env is gitignored.
# Leave ANTHROPIC_API_KEY empty on public deployments if visitors should bring
# their own key in the UI.
ANTHROPIC_API_KEY=

# Optional model overrides.
ANTHROPIC_PLANNER_MODEL=
ANTHROPIC_FAST_MODEL=
ANTHROPIC_MODEL=

# Runtime configuration.
PORT=3000
CACHE_DIR=./cache
YTDLP_BIN=
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_B64=
